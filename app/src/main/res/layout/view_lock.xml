<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_height="match_parent"
    android:orientation="vertical"
    style="@style/VerticalListDivided">

    <!-- Pin Pad -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/bg_2"
        android:orientation="vertical"
        android:gravity="center">

        <GridLayout
            android:layout_width="250sp"
            android:layout_height="375sp"
            android:columnCount="3"
            android:useDefaultMargins="true">

            <EditText
                android:id="@+id/pin_display"
                android:layout_columnSpan="3"
                android:inputType="numberPassword"
                android:layout_margin="8sp"
                android:gravity="center"
                android:maxLength="25"
                android:focusable="false"
                android:clickable="false"
                android:layout_marginBottom="8sp"
                android:text=""
                style="@style/EditText" />

            <Button
                android:id="@+id/btn1"
                android:text="1"
                style="@style/PinButton" />

            <Button
                android:id="@+id/btn2"
                android:text="2"
                style="@style/PinButton" />

            <Button
                android:id="@+id/btn3"
                android:text="3"
                style="@style/PinButton" />

            <Button
                android:id="@+id/btn4"
                android:text="4"
                style="@style/PinButton" />

            <Button
                android:id="@+id/btn5"
                android:text="5"
                style="@style/PinButton" />

            <Button
                android:id="@+id/btn6"
                android:text="6"
                style="@style/PinButton" />

            <Button
                android:id="@+id/btn7"
                android:text="7"
                style="@style/PinButton" />

            <Button
                android:id="@+id/btn8"
                android:text="8"
                style="@style/PinButton" />

            <Button
                android:id="@+id/btn9"
                android:text="9"
                style="@style/PinButton" />

            <Space
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_columnWeight="1" />

            <Button
                android:id="@+id/btn0"
                android:text="0"
                style="@style/PinButton" />

            <Space
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_columnWeight="1" />

        </GridLayout>
    </LinearLayout>

    <!-- Actions -->
    <Button
        android:id="@+id/unlock_button"
        android:text="@string/btn_unlock"
        style="@style/BTN2" />

    <Button
        android:id="@+id/clear_button"
        android:text="@string/btn_clear"
        style="@style/BTN2" />

    <Button
        android:id="@+id/close_button"
        android:text="@string/btn_go_back"
        style="@style/BTN1" />

    <!-- Easter Egg Overlay -->
    <TextView
        android:id="@+id/easter_egg_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/easter_eggs_unlock"
        android:textSize="18sp"
        android:gravity="center"
        android:padding="16dp"
        android:visibility="gone"
        android:background="@color/bg_2"
        android:textColor="@color/danger" />

    <!-- Easter Egg Counter -->
    <TextView
        android:id="@+id/easter_egg_counter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:gravity="center"
        android:padding="8dp"
        android:visibility="gone"
        android:textColor="@color/accent_1" />

</LinearLayout>