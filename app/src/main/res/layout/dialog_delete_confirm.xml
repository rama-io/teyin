<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:padding="16sp"
    android:background="@color/bg_1"
    style="@style/VerticalListDivided">

    <TextView
        android:id="@+id/delete_title"
        android:text="@string/dialog_delete_title"
        style="@style/H2_center" />

    <TextView
        android:id="@+id/delete_count_label"
        android:gravity="center"
        style="@style/Text" />

    <Button
        android:id="@+id/yes_button"
        android:text="@string/btn_delete_confirm"
        style="@style/BTN_danger" />

    <Button
        android:id="@+id/no_button"
        android:text="@string/btn_cancel"
        style="@style/BTN1" />
</LinearLayout>