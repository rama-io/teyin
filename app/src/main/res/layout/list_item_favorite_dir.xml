<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:baselineAligned="false"
    android:descendantFocusability="blocksDescendants"
    android:background="@color/bg_2"
    android:padding="8sp"
    style="@style/HorizontalList">

    <FrameLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="12sp">

        <ImageView
            android:id="@+id/dir_icon"
            android:src="@drawable/px_folder"
            android:tint="@color/accent_3"
            android:contentDescription="@string/altdescr_favorite_folder"
            style="@style/Icon24" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingTop="10sp"
        android:paddingBottom="10sp">

        <TextView
            android:id="@+id/dir_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/foreground"
            android:maxLines="1"
            android:ellipsize="end"
            style="@style/Text" />

        <TextView
            android:id="@+id/dir_path"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/disabled"
            android:singleLine="true"
            android:ellipsize="start"
            android:textSize="11sp" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/remove_favorite_btn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="12sp">

        <ImageView
            android:src="@drawable/px_times"
            android:contentDescription="@string/altdescr_remove_favorite"
            style="@style/Icon24" />
    </FrameLayout>

</LinearLayout>
